{
  "installCommand": "NODE_NO_WARNINGS=1 yarn install --frozen-lockfile",
  "buildCommand": "yarn build",
  "outputDirectory": "frontend/public",
  "rewrites": [
    {
      "source": "/api",
      "destination": "/api/index"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    }
  ]
}
